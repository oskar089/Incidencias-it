PORT=3001
JWT_SECRET=change-me-to-a-secure-random-string-min-32-chars
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# Supabase (PostgreSQL)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Default admin credentials (auto-created if no admin exists)
ADMIN_EMAIL=admin@incidencias.com
ADMIN_PASSWORD=Admin12345

# Twilio Configuration (for SMS notifications)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE=+1234567890

# Technician phone number (for SMS notifications)
TECHNICIAN_PHONE=+1234567890
